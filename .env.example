# SQLite-Datei (lokal: prisma/dev.db, Pi: /opt/drinks/data/drinks.db)
DATABASE_URL="file:./dev.db"

# Cookie-Geheimnis (mind. 32 Zeichen). Erzeugen z.B. mit:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="bitte-mit-langem-zufallswert-ersetzen-mind-32-zeichen"

# Optional: Anfangs-PIN für den geseedeten Admin (sonst 0000)
ADMIN_PIN="0000"

# Optional: queryid für die OpenGTIN-DB (Barcode-Lookup).
# Registrierung: https://opengtindb.org/  (kostenlos, Mail an register@opengtindb.org)
# Ohne gültige queryid liefert die API "error=5" und der Scanner fällt auf
# manuelle Kategoriewahl zurück (Barcode wird trotzdem gemerkt).
OPENGTIN_QUERYID=""
