generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String    @unique
  pinHash   String
  role      String    @default("member") // "member" | "admin"
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tallies      Tally[]
  auditEntries AuditLog[] @relation("Actor")

  @@index([deletedAt])
}

model Category {
  id         String  @id @default(cuid())
  key        String  @unique // "kat1".."kat5", "custom-..."
  label      String
  color      String  // hex
  sortOrder  Int     @default(0)
  freetext   Boolean @default(false) // wenn true: Tap öffnet Texteingabe statt direkt zu buchen
  priceCents Int     @default(0) // Preis in Cent. 0 = kostenlos. Nur im Admin sichtbar.

  tallies  Tally[]
  products Product[]
}

model Branding {
  id        String   @id @default("default")
  logoBytes Bytes?
  logoMime  String?
  updatedAt DateTime @updatedAt
}

model Product {
  id         String   @id @default(cuid())
  ean        String   @unique
  name       String
  categoryId String
  source     String   @default("manual") // "opengtin" | "manual"
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id])
  tallies  Tally[]
}

model Tally {
  id         String    @id @default(cuid())
  userId     String
  categoryId String
  productId  String?
  source     String    @default("tap") // "tap" | "scan" | "admin" | "kiosk"
  amount     Int       @default(1)
  note       String?
  createdAt  DateTime  @default(now())
  createdBy  String? // userId des Admins, falls nachträglich gebucht
  deletedAt  DateTime?
  deletedBy  String? // userId der Person, die rückgängig gemacht hat

  user     User      @relation(fields: [userId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])

  @@index([userId, createdAt])
  @@index([categoryId, createdAt])
  @@index([deletedAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String
  action       String
  targetTable  String
  targetId     String
  before       String?
  after        String?
  createdAt    DateTime @default(now())

  actor User @relation("Actor", fields: [actorUserId], references: [id])
}

model BarcodeCache {
  ean       String   @id
  payload   String
  fetchedAt DateTime @default(now())
}
